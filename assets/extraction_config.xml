<?xml version="1.0" encoding="utf-8"?>
<ExtractionConfig>

	<OCR>
		<MinConfidence>60</MinConfidence>
	</OCR>

	<Patterns>

		<!-- Strict industrial tag format (must end in digits only) -->
		<Pattern>
			<Name>GENERIC_INDUSTRIAL_TAG</Name>
			<Type>TAG</Type>
			<Regex><![CDATA[\b[A-Z]{2,6}-[A-Z0-9]{2,15}-[A-Z0-9]{4,15}[A-Z]?\b]]></Regex>
		</Pattern>

		<!-- Structured Equipment (Domain Generic) -->
		<Pattern>
			<Name>EQUIP_STRUCT_BASIC</Name>
			<Type>EQUIP</Type>
			<Regex><![CDATA[\b(?:MCC|PANEL|TANK|DRIVE|UPS|TRANSFORMER)-?[A-Z0-9]{1,6}\b]]></Regex>
		</Pattern>

		<Pattern>
			<Name>EQUIP_ROTATING</Name>
			<Type>EQUIP</Type>
			<Regex><![CDATA[\b(?:MOTOR|PUMP|MIXER|FAN|BLOWER)-?[A-Z0-9]{1,6}\b]]></Regex>
		</Pattern>

		<Pattern>
			<Name>EQUIP_COMPACT</Name>
			<Type>EQUIP</Type>
			<Regex><![CDATA[\b(?:MOTOR|PUMP|VFD|DRIVE|PANEL|VALVE|TANK|UPS|MCC|COMPRESSOR|FAN|BLOWER|MIXER|TRANSFORMER)-?\d{1,5}\b]]></Regex>
		</Pattern>

		<!-- ABB VFD Models -->
		<Pattern>
			<Name>VFD_MODEL</Name>
			<Type>MODEL</Type>
			<Regex><![CDATA[\bACS880-\d{2}-\d{4}-\d\b]]></Regex>
		</Pattern>

		<Pattern>
			<Name>VFD_MODEL_POWER</Name>
			<Type>TAG</Type>
			<Regex><![CDATA[\bACS880-\d{2}-\d{4}-\d\s*\d+[.,]?\d*kW\b]]></Regex>
		</Pattern>

		<!-- Requisition numbers -->
		<Pattern>
			<Name>REQUISITION_NO</Name>
			<Type>TAG</Type>
			<Regex><![CDATA[\bET-J\d{2}N\d{2}-[A-Z0-9]{5,25}\b]]></Regex>
		</Pattern>

		<!-- Strict + prefixed tags -->
		<Pattern>
			<Name>PREFIX_TAG</Name>
			<Type>TAG</Type>
			<Regex><![CDATA[\b\+[A-Z0-9]{2,6}(?:-\d{1,3})?\b]]></Regex>
		</Pattern>

		<!-- Standards -->
		<Pattern>
			<Name>STANDARD</Name>
			<Type>TAG</Type>
			<Regex><![CDATA[\b(?:IS|IEC|ISO)\s?\d{4,6}(?:\s?Part\s?\d+)?\b]]></Regex>
		</Pattern>

	</Patterns>


	<!-- Domain-level equipment keywords -->
	<EquipmentKeywords>
		<Word>UPS</Word>
		<Word>BATTERY</Word>
		<Word>RECTIFIER</Word>
		<Word>INVERTER</Word>
		<Word>CIRCUIT_BREAKER</Word>
		<Word>ACB</Word>
		<Word>MCCB</Word>
		<Word>MOTOR</Word>
		<Word>PUMP</Word>
		<Word>VFD</Word>
		<Word>COMPRESSOR</Word>
		<Word>FAN</Word>
		<Word>BLOWER</Word>
		<Word>MIXER</Word>
		<Word>TRANSFORMER</Word>
		<Word>TANK</Word>
		<Word>VALVE</Word>
		<Word>PANEL</Word>
		<Word>MCC</Word>
		<Word>CUBICLE</Word>
	</EquipmentKeywords>


	<!-- Generic document structure words -->
	<RejectLines>
		<Word>PAGE</Word>
		<Word>REVISION</Word>
		<Word>ANNEXURE</Word>
		<Word>SECTION</Word>
		<Word>FIGURE</Word>
		<Word>TABLE</Word>
		<Word>VENDOR</Word>
		<Word>BUYER</Word>
		<Word>BIDDER</Word>
		<Word>SPECIFICATION</Word>
		<Word>ATTACHMENT</Word>
		<Word>CONTRACT</Word>
	</RejectLines>

</ExtractionConfig>